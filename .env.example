# =============================================================================
# AutoFinance Pro — variables de entorno
# =============================================================================
# Uso local:
#   cp .env.example .env
#   Edita .env con tus valores (nunca commitees .env)
#   docker compose up --build
#
# Railway: configura las mismas variables en el dashboard de cada servicio.
# Ver DEPLOY-RAILWAY.md para el despliegue paso a paso.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (solo docker-compose local)
# -----------------------------------------------------------------------------
POSTGRES_USER=autofinance
POSTGRES_PASSWORD=autofinance123
POSTGRES_DB=autofinance_db

# -----------------------------------------------------------------------------
# Backend — base de datos
# -----------------------------------------------------------------------------
# Local (docker-compose): host = postgres (nombre del servicio)
DATABASE_URL=postgresql+psycopg2://autofinance:autofinance123@postgres:5432/autofinance_db

# Railway: usa referencia al plugin Postgres
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# (Railway entrega postgresql://...; el backend lo normaliza automáticamente)

# -----------------------------------------------------------------------------
# Backend — autenticación JWT
# -----------------------------------------------------------------------------
# Genera una clave nueva para producción (openssl rand -hex 32)
SECRET_KEY=autofinance-pro-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# -----------------------------------------------------------------------------
# Backend — CORS
# -----------------------------------------------------------------------------
# Orígenes permitidos del frontend, separados por coma (sin espacios extra)
# Local:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Railway (ejemplo):
# CORS_ORIGINS=https://frontend-production-xxxx.up.railway.app

# -----------------------------------------------------------------------------
# Backend — SMTP (2FA por email)
# -----------------------------------------------------------------------------
# Dejar SMTP_HOST vacío en dev → el código OTP se imprime en logs del backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Gmail: SMTP_FROM debe ser el mismo email que SMTP_USER
SMTP_FROM=
SMTP_USE_TLS=true

# Ejemplo Gmail (descomenta y completa para probar 2FA local):
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=tu-correo@gmail.com

# -----------------------------------------------------------------------------
# Backend — OTP (2FA)
# -----------------------------------------------------------------------------
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# -----------------------------------------------------------------------------
# Backend — usuarios demo (bypass 2FA)
# -----------------------------------------------------------------------------
# Días de validez del token demo creado en seed para admin/vendedor/soporte
DEMO_ACCESS_TOKEN_DAYS=365

# -----------------------------------------------------------------------------
# Backend — puerto (Railway lo inyecta automáticamente)
# -----------------------------------------------------------------------------
# Local docker-compose: fijo en 8000
PORT=8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# URL base del API (sin /api/v1 — el cliente lo añade)
# Local:
VITE_API_URL=http://localhost:8000
# Railway (build time — obligatorio al compilar el frontend):
# VITE_API_URL=https://backend-production-xxxx.up.railway.app

# -----------------------------------------------------------------------------
# Scripts de prueba (opcional)
# -----------------------------------------------------------------------------
# Destinatario para backend/scripts/test_smtp_send.py
TEST_EMAIL_TO=tu-correo@gmail.com
